{
  "name": "@deltex/client",
  "version": "1.4.0",
  "description": "Official TypeScript/JavaScript client for Deltex \u2014 edge-native SQL database",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./serverless": {
      "import": "./dist/serverless.mjs",
      "require": "./dist/serverless.js",
      "types": "./dist/serverless.d.ts"
    },
    "./drizzle": {
      "import": "./dist/drizzle.mjs",
      "require": "./dist/drizzle.js",
      "types": "./dist/drizzle.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/serverless.ts src/drizzle.ts --format cjs,esm --dts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "deltex",
    "sql",
    "database",
    "edge",
    "fastly",
    "postgres",
    "serverless",
    "drizzle",
    "neon"
  ],
  "license": "MIT",
  "peerDependencies": {
    "drizzle-orm": ">=0.30.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@jest/globals": "^29.0.0",
    "ts-jest": "^29.0.0",
    "drizzle-orm": "^0.36.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trydeltex/deltex-js.git"
  },
  "homepage": "https://deltex.dev",
  "bugs": {
    "url": "https://github.com/trydeltex/deltex-js/issues"
  }
}
